# ===============================
# APP ENV
# ===============================
APP_ENV=development
MODEL_STAGE=Production

# ===============================
# MINIO (AWS EC2)
# ===============================
MINIO_ENDPOINT=16.170.221.82:9000

MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123

MINIO_BUCKET_DATA=data
MINIO_BUCKET_IMAGES=images

MINIO_X_TRAIN_KEY=X_train.csv
MINIO_Y_TRAIN_KEY=y_train.csv
MINIO_X_TEST_KEY=X_test.csv
MINIO_Y_RANDOM_KEY=y_random.csv

IMAGE_SOURCE=minio
MINIO_IMAGE_PREFIX=

# ===============================
# POSTGRES (LOCAL DOCKER OR RDS)
# ===============================
DB_BACKEND=postgres

# 👉 OPTION A: If using Docker DB locally
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# 👉 OPTION B: If using AWS RDS (replace this)
# POSTGRES_HOST=your-rds-endpoint.amazonaws.com

POSTGRES_DB=rakuten
POSTGRES_USER=rakuten_user
POSTGRES_PASSWORD=rakuten_pass

DATABASE_URL=postgresql://rakuten_user:rakuten_pass@localhost:5432/rakuten

# ===============================
# MLFLOW
# ===============================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=rakuten_color_extraction

MLFLOW_S3_ENDPOINT_URL=http://16.170.221.82:9000
AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=password123
AWS_DEFAULT_REGION=us-east-1

# ===============================
# TRAINING (ICE)
# ===============================
ICE_BATCH_SIZE=128
ICE_LR=0.003
ICE_ENCODER_LR=0.00002
ICE_MAX_EPOCHS=15
ICE_UNFREEZE_LAYERS=2
ICE_ES_PATIENCE=3

ICE_VAL_THRESHOLD=0.5
ICE_TRAIN_THRESHOLD=0.5

ICE_MAX_LEN=128

DB_TRAIN_SPLIT=train
PREDICT_SPLIT=val
VAL_RATIO=0.1