# ============================================================
# Rakuten Color Extraction — Environment Config
# Single source of truth for all credentials and settings.
# Change a value here → applies everywhere automatically.
# ============================================================
 
# -- MinIO credentials (used by minio, mlflow, api, training) --
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
 
# -- AWS-style aliases (same values, required by boto3/mlflow) --
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
 
# -- MinIO endpoints --
# WSL (browser/Python direct):   localhost:9000
# Container-internal (compose):  minio:9000
MINIO_ENDPOINT=localhost:9000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
 
# -- MinIO buckets --
MINIO_BUCKET_DATA=rakuten-data
MINIO_BUCKET_IMAGES=rakuten-images
MINIO_IMAGE_PREFIX=
 
# -- PostgreSQL credentials --
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mlflow:mlflow@localhost:5432/mlflow
 
# -- MLflow --
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=rakuten_color_extraction
MLFLOW_REGISTERED_MODEL_NAME=rakuten-ice-dual-encoder
MLFLOW_CHAMPION_ALIAS=champion
MLFLOW_CANDIDATE_ALIAS=candidate
 
# -- Image loading: "local" for WSL, "minio" for container --
IMAGE_SOURCE=local
IMAGE_DIR=/home/mirco/rakuten2/data/images
 
# -- Training --
ICE_MAX_EPOCHS=1
APP_ENV=development