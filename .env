# -- MinIO credentials --
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# -- MinIO endpoints --
MINIO_ENDPOINT=localhost:9000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

# -- MinIO buckets --
MINIO_BUCKET_DATA=rakuten-data
MINIO_BUCKET_IMAGES=rakuten-images
MINIO_IMAGE_PREFIX=

# -- PostgreSQL --
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://mlflow:mlflow@localhost:5432/mlflow

# -- MLflow --
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=rakuten_color_extraction
MLFLOW_REGISTERED_MODEL_NAME=rakuten-ice-dual-encoder
MLFLOW_CHAMPION_ALIAS=champion
MLFLOW_CANDIDATE_ALIAS=candidate

# -- Image source: "local" or "minio" --
IMAGE_SOURCE=local

# -- Training --
ICE_MAX_EPOCHS=1
APP_ENV=development
