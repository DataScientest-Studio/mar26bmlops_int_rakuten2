# ===============================
# APP
# ===============================
APP_ENV=development
MODEL_STAGE=Production

# ===============================
# DATA SOURCE
# ===============================
IMAGE_SOURCE=minio
DATA_SOURCE=minio

# ===============================
# POSTGRES (container-native)
# ===============================
DB_BACKEND=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rakuten
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rakuten

# ===============================
# MLFLOW
# ===============================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=rakuten_color_extraction
MLFLOW_REGISTERED_MODEL_NAME=rakuten-ice-dual-encoder
MLFLOW_CHAMPION_ALIAS=champion
MLFLOW_CANDIDATE_ALIAS=candidate
MLFLOW_BACKEND_STORE_URI=postgresql://postgres:postgres@postgres:5432/mlflow_meta
MLFLOW_S3_ENDPOINT_URL=http://minio:9000


# ===============================
# AIRFLOW
# ===============================


AIRFLOW_DB=airflow
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow



# ===============================
# MINIO / S3 (container-native)
# ===============================
MINIO_ENDPOINT=minio:9000

MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=pwd_123_SIMV
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=pwd_123_SIMV

AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=pwd_123_SIMV
AWS_DEFAULT_REGION=us-east-1

# ===============================
# MINIO BUCKETS / KEYS
# ===============================
MINIO_BUCKET_DATA=data
MINIO_BUCKET_IMAGES=images

MINIO_X_TRAIN_KEY=X_train.csv
MINIO_Y_TRAIN_KEY=y_train.csv
MINIO_X_TEST_KEY=X_test.csv
MINIO_Y_RANDOM_KEY=y_random.csv

MINIO_IMAGE_PREFIX=

# ===============================
# TRAINING (ICE)
# ===============================
ICE_BATCH_SIZE=128
ICE_LR=0.003
ICE_ENCODER_LR=0.00002
ICE_MAX_EPOCHS=1
ICE_UNFREEZE_LAYERS=2
ICE_ES_PATIENCE=3

ICE_VAL_THRESHOLD=0.5
ICE_TRAIN_THRESHOLD=0.5
ICE_MAX_LEN=128

DB_TRAIN_SPLIT=train
PREDICT_SPLIT=val
VAL_RATIO=0.1