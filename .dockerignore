# -------------------------------------------------------
# .dockerignore
# Keeps build context lean, faster builds, smaller images
# -------------------------------------------------------

# Python cache
.venv
venv
__pycache__
*.pyc
*.pyo
*.pyd
.Python
.pytest_cache
.ipynb_checkpoints

# Git
.git
.gitignore
.github

# Data & models (mounted as volumes at runtime, not baked in)
data/
models/
mlflow/
mlruns/

# DVC (metadata only in image, actual data via volumes)
*.dvc
.dvc/tmp
.dvc/cache

# Databases
*.db
*.sqlite
*.sqlite3

# Reports & notebooks (not needed in container)
reports/
notebooks/
references/

# Build artifacts
dist/
build/
*.egg-info

# OS
.DS_Store

# Secrets (never bake these in!)
.env
*.pem
*.key