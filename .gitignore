.ipynb_checkpoints/

# exclude data from source control by default
# ignore all data files
/data/*

# keep folder structure
!/data/raw/
!/data/processed/
!/data/external/
!/data/interim/

# keep placeholder files
!/data/raw/.gitkeep
!/data/processed/.gitkeep
!/data/external/.gitkeep
!/data/interim/.gitkeep

# Mac OS-specific storage files
.DS_Store

# vim
*.swp
*.swo

# Mypy cache
.mypy_cache/



# mk _________________________________________________________
# ignore virtual env
venv/
.venv/

# ignore all data
data/*

# keep folder structure
!data/raw/
!data/processed/
!data/external/
!data/interim/

# keep placeholder files
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!data/interim/.gitkeep

# ignore everything in data
data/*

# but keep folder structure
!data/raw/
!data/processed/
!data/external/
!data/interim/

# ignore all files inside these folders
data/raw/*
data/processed/*
data/external/*
data/interim/*

# but keep .gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
!data/interim/.gitkeep

# DB folder
db/
models/*.pt

# models
*.pkl
models/*.pkl
pth
*.pth
